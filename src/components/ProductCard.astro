---
import type { Product } from '../lib/content';
interface Props {
  product: Product;
  imgHeight?: number;
}
const { product, imgHeight = 172 } = Astro.props;
const thumb = product.gallery[0]?.src ?? null;
---
<a href={`/catalog/${product.slug}`} class="product-card">
  <div class="img-placeholder" style={`height:${imgHeight}px;position:relative`}>
    {thumb
      ? <img src={thumb} alt={product.gallery[0]?.label ?? product.name} style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0" loading="lazy" />
      : <span>NO IMAGE</span>
    }
  </div>
  <div style="padding:15px 17px;display:flex;flex-direction:column;gap:9px;flex:1">
    <div style="display:flex;gap:7px;align-items:center">
      <span style="background:#eef1f3;color:#374754;font:600 11px Barlow;padding:3px 9px;border-radius:20px">{product.category}</span>
      <span style="color:#FD843B;font:600 11px Barlow">{product.condition}</span>
    </div>
    <div style="font:700 16px Archivo;color:#374754;line-height:1.25">{product.name}</div>
    <div style="font:400 13.5px/1.5 Barlow;color:#6b7780">{product.shortDesc}</div>
    <div style="margin-top:auto;font:600 13px Barlow;color:#374754">View details →</div>
  </div>
</a>

---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import { loadProducts, loadSettings, loadCategories, loadConditions } from '../../lib/content';

// Seed the admin with the real content files. In local (demo) mode the client
// overlays localStorage on top of this seed; in production the GitHub store
// (added at deploy time) reads/writes the same files via the GitHub API.
const products = loadProducts();
const settings = loadSettings();
const categories = loadCategories();
const conditions = loadConditions();

const seed = {
  products: products.map((p) => ({
    id: p.id, slug: p.slug, name: p.name, category: p.category, condition: p.condition,
    sku: p.sku, shortDesc: p.shortDesc, description: p.description,
    gallery: p.gallery, specs: p.specs, compatibility: p.compatibility,
  })),
  categories, conditions, settings,
};
---
<Base title="Product manager">
  <Nav />
  <div class="pad" style="padding-top:40px;padding-bottom:64px;background:#f7f9fa;min-height:70vh">

    <!-- Header -->
    <div style="display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;margin-bottom:6px">
      <div>
        <h1 style="font:800 30px Archivo;color:#374754;letter-spacing:-.02em;margin:0">Product manager</h1>
        <div id="admin-subtitle" style="font:400 14px Barlow;color:#6b7780;margin-top:4px"></div>
      </div>
      <button id="btn-add" style="background:#FD843B;color:#fff;padding:12px 22px;border-radius:9px;font:600 15px Barlow;cursor:pointer;border:none">+ Add product</button>
    </div>

    <!-- Catalog filters card -->
    <div style="background:#fff;border:1px solid #eef1f3;border-radius:14px;padding:22px 24px;margin-top:22px">
      <div style="font:700 17px Archivo;color:#374754;letter-spacing:-.01em">Catalog filters</div>
      <div style="font:400 13.5px/1.5 Barlow;color:#6b7780;margin-top:4px;max-width:640px">Choose which categories appear as quick filter chips at the top of the catalog. Every category is always available in the catalog's filter sidebar — these just promote the ones you use most.</div>
      <div id="chip-tags" style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-top:16px;min-height:34px"></div>
      <select id="chip-add" style="width:100%;max-width:320px;height:44px;border:1.5px solid #d8dee3;border-radius:9px;padding:0 11px;font:400 14px Barlow;color:#374754;background:#fff;margin-top:12px"></select>
      <div style="border-top:1px solid #eef1f3;margin-top:20px;padding-top:16px">
        <div id="cond-toggle" style="display:inline-flex;align-items:center;gap:11px;cursor:pointer">
          <div id="cond-box" style="width:20px;height:20px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:12px;color:#fff;flex:none"></div>
          <div>
            <div style="font:600 14px Barlow;color:#374754">Show the Condition filter</div>
            <div style="font:400 12.5px Barlow;color:#9aa6ae">Lets shoppers filter the catalog by New, Refurbished, etc.</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Home page categories card -->
    <div style="background:#fff;border:1px solid #eef1f3;border-radius:14px;padding:22px 24px;margin-top:16px">
      <div style="font:700 17px Archivo;color:#374754;letter-spacing:-.01em">Home page categories</div>
      <div style="font:400 13.5px/1.5 Barlow;color:#6b7780;margin-top:4px;max-width:640px">Choose which categories show in the "Shop by category" panel on the home page. "All parts" always stays at the top.</div>
      <div id="home-tags" style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-top:16px;min-height:34px"></div>
      <select id="home-add" style="width:100%;max-width:320px;height:44px;border:1.5px solid #d8dee3;border-radius:9px;padding:0 11px;font:400 14px Barlow;color:#374754;background:#fff;margin-top:12px"></select>
    </div>

    <!-- Search -->
    <div style="display:flex;align-items:center;gap:10px;margin-top:20px;max-width:440px;border:1.5px solid #d8dee3;border-radius:10px;padding:0 14px;height:46px;background:#fff">
      <span style="color:#9aa6ae;font-size:15px">⌕</span>
      <input id="admin-search" placeholder="Search products by name, ref or category…" style="flex:1;border:none;height:44px;font:400 14px Barlow;color:#374754;background:transparent" autocomplete="off" />
    </div>

    <!-- Product table -->
    <div style="background:#fff;border:1px solid #eef1f3;border-radius:14px;overflow:hidden;margin-top:14px">
      <div style="display:grid;grid-template-columns:2.4fr 1fr 1fr 130px;gap:12px;padding:14px 20px;border-bottom:1px solid #eef1f3;font:600 12px Barlow;letter-spacing:.04em;color:#9aa6ae;text-transform:uppercase">
        <div>Product</div><div class="hide-xs">Category</div><div class="hide-xs">Condition</div><div style="text-align:right">Actions</div>
      </div>
      <div id="admin-rows"></div>
    </div>
    <div class="pager" id="admin-pager" style="display:none"></div>

    <div id="save-status" style="font:400 12.5px Barlow;color:#9aa6ae;margin-top:14px"></div>
  </div>

  <!-- Add/Edit modal -->
  <div id="modal" style="display:none;position:fixed;inset:0;z-index:100;background:rgba(45,58,69,.5);align-items:flex-start;justify-content:center;padding:40px 20px;overflow:auto">
    <div style="background:#fff;border-radius:16px;width:100%;max-width:580px;padding:28px;box-shadow:0 24px 60px rgba(0,0,0,.25)">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
        <div id="modal-title" style="font:800 22px Archivo;color:#374754">Add product</div>
        <button id="modal-close" style="cursor:pointer;color:#9aa6ae;font-size:22px;line-height:1;background:none;border:none">×</button>
      </div>
      <div style="display:flex;flex-direction:column;gap:16px">
        <div>
          <div style="font:600 13px Barlow;color:#374754;margin-bottom:6px">Product name *</div>
          <input id="f-name" placeholder="e.g. Headlight Assembly" style="width:100%;height:46px;border:1.5px solid #d8dee3;border-radius:9px;padding:0 13px;font:400 15px Barlow;color:#374754" />
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
          <div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px"><span style="font:600 13px Barlow;color:#374754">Category</span><span id="cat-manage" style="font:600 11px Barlow;color:#FD843B;cursor:pointer">Manage</span></div>
            <select id="f-category" style="width:100%;height:46px;border:1.5px solid #d8dee3;border-radius:9px;padding:0 11px;font:400 15px Barlow;color:#374754;background:#fff"></select>
            <div id="cat-manage-panel" style="display:none;margin-top:8px;border:1px solid #eef1f3;border-radius:10px;padding:10px;background:#f7f9fa">
              <div style="display:flex;gap:6px">
                <input id="cat-new" placeholder="New category name" style="flex:1;min-width:0;height:38px;border:1.5px solid #d8dee3;border-radius:8px;padding:0 11px;font:400 14px Barlow;color:#374754" />
                <button id="cat-add" style="background:#374754;color:#fff;padding:0 14px;height:38px;border-radius:8px;font:600 13px Barlow;cursor:pointer;border:none">Add</button>
              </div>
              <div id="cat-manage-list" style="display:flex;flex-wrap:wrap;gap:6px;margin-top:10px"></div>
            </div>
          </div>
          <div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px"><span style="font:600 13px Barlow;color:#374754">Condition</span><span id="cond-manage" style="font:600 11px Barlow;color:#FD843B;cursor:pointer">Manage</span></div>
            <select id="f-condition" style="width:100%;height:46px;border:1.5px solid #d8dee3;border-radius:9px;padding:0 11px;font:400 15px Barlow;color:#374754;background:#fff"></select>
            <div id="cond-manage-panel" style="display:none;margin-top:8px;border:1px solid #eef1f3;border-radius:10px;padding:10px;background:#f7f9fa">
              <div style="display:flex;gap:6px">
                <input id="cond-new" placeholder="New condition name" style="flex:1;min-width:0;height:38px;border:1.5px solid #d8dee3;border-radius:8px;padding:0 11px;font:400 14px Barlow;color:#374754" />
                <button id="cond-add" style="background:#374754;color:#fff;padding:0 14px;height:38px;border-radius:8px;font:600 13px Barlow;cursor:pointer;border:none">Add</button>
              </div>
              <div id="cond-manage-list" style="display:flex;flex-wrap:wrap;gap:6px;margin-top:10px"></div>
            </div>
          </div>
        </div>
        <div>
          <div style="font:600 13px Barlow;color:#374754;margin-bottom:6px">Part reference</div>
          <input id="f-sku" placeholder="e.g. AS-LT-1042" style="width:100%;height:46px;border:1.5px solid #d8dee3;border-radius:9px;padding:0 13px;font:400 15px Barlow;color:#374754" />
        </div>
        <div>
          <div style="font:600 13px Barlow;color:#374754;margin-bottom:6px">Short description</div>
          <input id="f-short" placeholder="One-line summary shown on cards" style="width:100%;height:46px;border:1.5px solid #d8dee3;border-radius:9px;padding:0 13px;font:400 15px Barlow;color:#374754" />
        </div>
        <div>
          <div style="font:600 13px Barlow;color:#374754;margin-bottom:6px">Full description</div>
          <textarea id="f-desc" placeholder="Detailed description for the product page" style="width:100%;height:96px;border:1.5px solid #d8dee3;border-radius:9px;padding:11px 13px;font:400 15px Barlow;color:#374754;resize:vertical"></textarea>
        </div>

        <!-- Images -->
        <div style="border-top:1px solid #eef1f3;padding-top:16px">
          <div style="font:600 13px Barlow;color:#374754;margin-bottom:4px">Product images</div>
          <div style="font:400 12px Barlow;color:#9aa6ae;margin-bottom:12px">One image shows as a single photo; two or more form a carousel. Drag images to reorder.</div>
          <div id="f-images" style="display:flex;flex-wrap:wrap;gap:10px;align-items:center"></div>
        </div>

        <!-- Specs -->
        <div style="border-top:1px solid #eef1f3;padding-top:16px">
          <div style="font:600 13px Barlow;color:#374754;margin-bottom:4px">Specifications</div>
          <div style="font:400 12px Barlow;color:#9aa6ae;margin-bottom:12px">Add key/value pairs. If you add none, the specifications section is hidden on the product page.</div>
          <div id="f-specs" style="display:flex;flex-direction:column;gap:8px"></div>
          <button id="spec-add" style="margin-top:10px;display:inline-flex;align-items:center;gap:6px;border:1.5px solid #d8dee3;color:#374754;padding:9px 16px;border-radius:8px;font:600 13px Barlow;cursor:pointer;background:#fff">+ Add specification</button>
        </div>

        <!-- Compatibility -->
        <div style="border-top:1px solid #eef1f3;padding-top:16px">
          <div style="font:600 13px Barlow;color:#374754;margin-bottom:4px">Compatibility (Fits)</div>
          <div style="font:400 12px Barlow;color:#9aa6ae;margin-bottom:12px">Vehicles this part fits, shown as the "Fits" list on the product page.</div>
          <div id="f-compat" style="display:flex;flex-direction:column;gap:8px"></div>
          <button id="compat-add" style="margin-top:10px;display:inline-flex;align-items:center;gap:6px;border:1.5px solid #d8dee3;color:#374754;padding:9px 16px;border-radius:8px;font:600 13px Barlow;cursor:pointer;background:#fff">+ Add vehicle</button>
        </div>
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:24px">
        <button id="modal-cancel" style="border:1.5px solid #d8dee3;color:#374754;padding:12px 22px;border-radius:9px;font:600 15px Barlow;cursor:pointer;background:#fff">Cancel</button>
        <button id="modal-save" style="background:#FD843B;color:#fff;padding:12px 26px;border-radius:9px;font:600 15px Barlow;cursor:pointer;border:none">Save product</button>
      </div>
    </div>
  </div>
</Base>

<script define:vars={{ seed }}>
  // ---------- data store (local/demo mode via localStorage) ----------
  // Structured so a GitHub-commit store can be swapped in for production.
  const LS = 'as_admin_v1';
  const slugify = (s) => (s || '').toString().toLowerCase().trim()
    .replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '') || 'product-' + Date.now();

  const store = {
    data: null,
    load() {
      let saved = null;
      try { saved = JSON.parse(localStorage.getItem(LS)); } catch {}
      this.data = saved && saved.products ? saved : JSON.parse(JSON.stringify({
        products: seed.products, categories: seed.categories,
        conditions: seed.conditions, settings: seed.settings,
      }));
      return this.data;
    },
    async persist() {
      // LOCAL mode: save to browser. PRODUCT mode (added on deploy): commit to
      // GitHub so the change rebuilds the live site. See README deploy section.
      try { localStorage.setItem(LS, JSON.stringify(this.data)); } catch {}
      status('Saved locally (demo). Online saving is added when the site is deployed.');
    },
    reset() { try { localStorage.removeItem(LS); } catch {} this.load(); },
  };

  // ---------- state ----------
  let d = store.load();
  let adminSearch = '';
  let adminPage = 1;
  const ADMIN_PER = 8;
  let form = null;          // null = modal closed
  let editingId = null;
  let dragFrom = null;

  const esc = (s) => String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  const $ = (id) => document.getElementById(id);
  function status(msg) { const el = $('save-status'); if (el) el.textContent = msg; }

  // category/condition option lists include any values in use by products
  function allCats() {
    const c = d.categories.slice();
    d.products.forEach((p) => { if (p.category && !c.includes(p.category)) c.push(p.category); });
    return c;
  }
  function allConds() {
    const c = d.conditions.slice();
    d.products.forEach((p) => { if (p.condition && !c.includes(p.condition)) c.push(p.condition); });
    return c;
  }
  const firstImg = (p) => (p.gallery || []).find((g) => g && g.src)?.src ?? null;

  // ---------- render: settings cards ----------
  function renderChips() {
    const wrap = $('chip-tags');
    const chips = (d.settings.chipCats || []).filter((c) => allCats().includes(c));
    if (chips.length === 0) {
      wrap.innerHTML = `<span style="font:400 13px Barlow;color:#9aa6ae">No quick chips — categories show only in the sidebar.</span>`;
    } else {
      wrap.innerHTML = chips.map((c) =>
        `<span style="display:inline-flex;align-items:center;gap:8px;background:#FD843B;color:#fff;font:600 13px Barlow;padding:6px 7px 6px 14px;border-radius:30px">${esc(c)} <span data-remove-chip="${esc(c)}" style="cursor:pointer;width:19px;height:19px;border-radius:50%;background:rgba(255,255,255,.25);display:flex;align-items:center;justify-content:center;font-size:13px;line-height:1">×</span></span>`
      ).join('');
    }
    wrap.querySelectorAll('[data-remove-chip]').forEach((b) => b.addEventListener('click', async () => {
      d.settings.chipCats = (d.settings.chipCats || []).filter((x) => x !== b.getAttribute('data-remove-chip'));
      await store.persist(); renderChips();
    }));
    // dropdown of not-yet-chosen cats
    const opts = allCats().filter((c) => !(d.settings.chipCats || []).includes(c));
    $('chip-add').innerHTML = `<option value="">+ Add a category as a chip…</option>` + opts.map((c) => `<option value="${esc(c)}">${esc(c)}</option>`).join('');
  }

  function renderHomeCats() {
    const wrap = $('home-tags');
    const cats = (d.settings.homeCats || []).filter((c) => allCats().includes(c));
    if (cats.length === 0) {
      wrap.innerHTML = `<span style="font:400 13px Barlow;color:#9aa6ae">No categories — the home panel will show only "All parts".</span>`;
    } else {
      wrap.innerHTML = cats.map((c) =>
        `<span style="display:inline-flex;align-items:center;gap:8px;background:#374754;color:#fff;font:600 13px Barlow;padding:6px 7px 6px 14px;border-radius:30px">${esc(c)} <span data-remove-home="${esc(c)}" style="cursor:pointer;width:19px;height:19px;border-radius:50%;background:rgba(255,255,255,.22);display:flex;align-items:center;justify-content:center;font-size:13px;line-height:1">×</span></span>`
      ).join('');
    }
    wrap.querySelectorAll('[data-remove-home]').forEach((b) => b.addEventListener('click', async () => {
      d.settings.homeCats = (d.settings.homeCats || []).filter((x) => x !== b.getAttribute('data-remove-home'));
      await store.persist(); renderHomeCats();
    }));
    const opts = allCats().filter((c) => !(d.settings.homeCats || []).includes(c));
    $('home-add').innerHTML = `<option value="">+ Add a category to the home panel…</option>` + opts.map((c) => `<option value="${esc(c)}">${esc(c)}</option>`).join('');
  }

  function renderCondToggle() {
    const on = d.settings.conditionFilter !== false;
    const box = $('cond-box');
    box.style.background = on ? '#FD843B' : '#fff';
    box.style.border = on ? '1.5px solid #FD843B' : '1.5px solid #c2cad0';
    box.textContent = on ? '✓' : '';
  }

  // ---------- render: table ----------
  function renderTable() {
    const q = adminSearch.trim().toLowerCase();
    const filtered = d.products.filter((p) => !q ||
      (p.name || '').toLowerCase().includes(q) ||
      (p.sku || '').toLowerCase().includes(q) ||
      (p.category || '').toLowerCase().includes(q));
    const totalPages = Math.max(1, Math.ceil(filtered.length / ADMIN_PER));
    adminPage = Math.min(adminPage, totalPages);
    const rows = filtered.slice((adminPage - 1) * ADMIN_PER, adminPage * ADMIN_PER);

    $('admin-subtitle').textContent = `${d.products.length} product${d.products.length === 1 ? '' : 's'} · changes save locally in this demo`;

    const container = $('admin-rows');
    if (filtered.length === 0) {
      container.innerHTML = `<div style="padding:34px 20px;text-align:center;font:400 14px Barlow;color:#9aa6ae">No products match your search.</div>`;
    } else {
      container.innerHTML = rows.map((p) => {
        const img = firstImg(p);
        const thumb = img
          ? `<img src="${esc(img)}" alt="" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover" />`
          : `${(p.gallery || []).length} img`;
        return `<div style="display:grid;grid-template-columns:2.4fr 1fr 1fr 130px;gap:12px;padding:14px 20px;border-bottom:1px solid #f1f4f6;align-items:center">
          <div style="display:flex;align-items:center;gap:12px;min-width:0">
            <div style="width:48px;height:48px;border-radius:8px;flex:none;overflow:hidden;position:relative;background:repeating-linear-gradient(135deg,#eef1f3 0 8px,#e7ebee 8px 16px);display:flex;align-items:center;justify-content:center;font:600 9px Barlow;color:#9aa6ae">${thumb}</div>
            <div style="min-width:0"><div style="font:700 14px Archivo;color:#374754;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(p.name)}</div><div style="font:400 12px Barlow;color:#9aa6ae">${esc(p.sku)}</div></div>
          </div>
          <div class="hide-xs" style="font:400 14px Barlow;color:#374754">${esc(p.category)}</div>
          <div class="hide-xs"><span style="background:#eef1f3;color:#374754;font:600 12px Barlow;padding:3px 10px;border-radius:20px">${esc(p.condition)}</span></div>
          <div style="display:flex;gap:8px;justify-content:flex-end">
            <button data-edit="${esc(p.id)}" style="border:1.5px solid #d8dee3;color:#374754;font:600 12px Barlow;padding:7px 13px;border-radius:7px;cursor:pointer;background:#fff">Edit</button>
            <button data-delete="${esc(p.id)}" style="border:1.5px solid #f0d4d4;color:#c0392b;font:600 12px Barlow;padding:7px 11px;border-radius:7px;cursor:pointer;background:#fff">Delete</button>
          </div>
        </div>`;
      }).join('');
      container.querySelectorAll('[data-edit]').forEach((b) => b.addEventListener('click', () => openEdit(b.getAttribute('data-edit'))));
      container.querySelectorAll('[data-delete]').forEach((b) => b.addEventListener('click', () => removeProduct(b.getAttribute('data-delete'))));
    }

    // pager
    const pager = $('admin-pager');
    if (totalPages <= 1) { pager.style.display = 'none'; }
    else {
      pager.style.display = 'flex';
      const pd = adminPage <= 1, nd = adminPage >= totalPages;
      let h = `<button class="pager-btn${pd ? ' pager-btn--disabled' : ''}" data-page="prev">←</button>`;
      for (let i = 1; i <= totalPages; i++) h += `<button class="pager-btn${i === adminPage ? ' pager-btn--active' : ''}" data-page="${i}">${i}</button>`;
      h += `<button class="pager-btn${nd ? ' pager-btn--disabled' : ''}" data-page="next">→</button>`;
      pager.innerHTML = h;
      pager.querySelectorAll('[data-page]').forEach((b) => b.addEventListener('click', () => {
        const v = b.getAttribute('data-page');
        if (v === 'prev') adminPage--; else if (v === 'next') adminPage++; else adminPage = +v;
        renderTable();
      }));
    }
  }

  function renderAll() { renderChips(); renderHomeCats(); renderCondToggle(); renderTable(); }

  // ---------- product delete ----------
  async function removeProduct(id) {
    if (!window.confirm('Delete this product?')) return;
    d.products = d.products.filter((p) => p.id !== id);
    await store.persist(); renderTable();
  }

  // ---------- modal ----------
  function openAdd() {
    editingId = null;
    form = { name:'', category: d.categories[0] || '', condition: d.conditions[0] || '', sku:'', shortDesc:'', description:'', gallery:[], specs:[], compatibility:[] };
    $('modal-title').textContent = 'Add product';
    fillModal(); showModal();
  }
  function openEdit(id) {
    const p = d.products.find((x) => x.id === id);
    if (!p) return;
    editingId = id;
    form = {
      name: p.name, category: p.category, condition: p.condition, sku: p.sku,
      shortDesc: p.shortDesc, description: p.description,
      gallery: (p.gallery || []).map((g) => ({ src: g.src || null, label: g.label || '' })),
      specs: (p.specs || []).map((s) => ({ label: s.label || '', value: s.value || '' })),
      compatibility: (p.compatibility || []).slice(),
    };
    $('modal-title').textContent = 'Edit product';
    fillModal(); showModal();
  }
  function showModal() { $('modal').style.display = 'flex'; }
  function closeModal() { $('modal').style.display = 'none'; form = null; $('cat-manage-panel').style.display = 'none'; $('cond-manage-panel').style.display = 'none'; }

  function fillModal() {
    $('f-name').value = form.name;
    $('f-sku').value = form.sku;
    $('f-short').value = form.shortDesc;
    $('f-desc').value = form.description;
    fillSelect('f-category', allCats(), form.category);
    fillSelect('f-condition', allConds(), form.condition);
    renderImages(); renderSpecs(); renderCompat();
  }
  function fillSelect(id, options, value) {
    $(id).innerHTML = options.map((o) => `<option value="${esc(o)}"${o === value ? ' selected' : ''}>${esc(o)}</option>`).join('');
  }

  function renderImages() {
    const wrap = $('f-images');
    const tiles = form.gallery.map((im, i) => {
      const inner = im.src
        ? `<img src="${esc(im.src)}" alt="" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover" />`
        : `<span>${esc(im.label || 'IMG')}</span>`;
      return `<div draggable="true" data-img="${i}" style="position:relative;width:74px;height:74px;border-radius:9px;overflow:hidden;border:1px solid #eef1f3;background:repeating-linear-gradient(135deg,#eef1f3 0 8px,#e7ebee 8px 16px);display:flex;align-items:center;justify-content:center;font:500 8px ui-monospace,monospace;color:#9aa6ae;text-align:center;padding:4px;flex:none;cursor:grab">
        ${inner}
        <span data-rmimg="${i}" style="position:absolute;top:3px;right:3px;width:19px;height:19px;border-radius:50%;background:rgba(45,58,69,.88);color:#fff;display:flex;align-items:center;justify-content:center;font-size:13px;line-height:1;cursor:pointer">×</span>
        ${i === 0 ? '<span style="position:absolute;bottom:0;left:0;right:0;background:rgba(253,132,59,.92);color:#fff;font:600 8px Barlow;text-align:center;padding:1px 0">PRIMARY</span>' : ''}
      </div>`;
    }).join('');
    wrap.innerHTML = tiles + `<label style="width:74px;height:74px;border:1.5px dashed #c2cad0;border-radius:9px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;color:#6b7780;font:600 10px Barlow;flex:none;text-align:center;gap:2px">
      <span style="font-size:20px;line-height:1">+</span>Upload
      <input type="file" accept="image/*" multiple id="img-upload" style="display:none" />
    </label>`;

    wrap.querySelectorAll('[data-rmimg]').forEach((b) => b.addEventListener('click', (e) => {
      e.stopPropagation();
      form.gallery.splice(+b.getAttribute('data-rmimg'), 1); renderImages();
    }));
    wrap.querySelectorAll('[data-img]').forEach((tile) => {
      tile.addEventListener('dragstart', () => { dragFrom = +tile.getAttribute('data-img'); });
      tile.addEventListener('dragover', (e) => e.preventDefault());
      tile.addEventListener('drop', (e) => {
        e.preventDefault();
        const to = +tile.getAttribute('data-img');
        if (dragFrom == null || dragFrom === to) return;
        const m = form.gallery.splice(dragFrom, 1)[0];
        form.gallery.splice(to, 0, m);
        dragFrom = null; renderImages();
      });
    });
    $('img-upload')?.addEventListener('change', onUpload);
  }

  function downscale(dataUrl, max, q) {
    return new Promise((res) => {
      try {
        const img = new Image();
        img.onload = () => {
          let w = img.width, h = img.height;
          if (w > max || h > max) { const r = Math.min(max / w, max / h); w = Math.round(w * r); h = Math.round(h * r); }
          const c = document.createElement('canvas'); c.width = w; c.height = h;
          c.getContext('2d').drawImage(img, 0, 0, w, h);
          try { res(c.toDataURL('image/jpeg', q)); } catch { res(dataUrl); }
        };
        img.onerror = () => res(dataUrl);
        img.src = dataUrl;
      } catch { res(dataUrl); }
    });
  }
  function onUpload(e) {
    const files = Array.from(e.target.files || []); e.target.value = '';
    files.forEach((file) => {
      const reader = new FileReader();
      reader.onload = () => downscale(reader.result, 1000, 0.82).then((src) => {
        form.gallery.push({ src, label: file.name }); renderImages();
      });
      reader.readAsDataURL(file);
    });
  }

  function renderSpecs() {
    const wrap = $('f-specs');
    wrap.innerHTML = form.specs.map((s, i) =>
      `<div style="display:flex;gap:8px;align-items:center">
        <input data-spec-label="${i}" value="${esc(s.label)}" placeholder="Label (e.g. Voltage)" style="flex:1;min-width:0;height:42px;border:1.5px solid #d8dee3;border-radius:8px;padding:0 12px;font:400 14px Barlow;color:#374754" />
        <input data-spec-value="${i}" value="${esc(s.value)}" placeholder="Value (e.g. 12V)" style="flex:1;min-width:0;height:42px;border:1.5px solid #d8dee3;border-radius:8px;padding:0 12px;font:400 14px Barlow;color:#374754" />
        <button data-spec-rm="${i}" style="width:40px;height:42px;border:1.5px solid #f0d4d4;color:#c0392b;border-radius:8px;cursor:pointer;flex:none;font-size:16px;background:#fff">×</button>
      </div>`
    ).join('');
    wrap.querySelectorAll('[data-spec-label]').forEach((el) => el.addEventListener('input', () => { form.specs[+el.getAttribute('data-spec-label')].label = el.value; }));
    wrap.querySelectorAll('[data-spec-value]').forEach((el) => el.addEventListener('input', () => { form.specs[+el.getAttribute('data-spec-value')].value = el.value; }));
    wrap.querySelectorAll('[data-spec-rm]').forEach((b) => b.addEventListener('click', () => { form.specs.splice(+b.getAttribute('data-spec-rm'), 1); renderSpecs(); }));
  }

  function renderCompat() {
    const wrap = $('f-compat');
    wrap.innerHTML = form.compatibility.map((c, i) =>
      `<div style="display:flex;gap:8px;align-items:center">
        <input data-compat="${i}" value="${esc(c)}" placeholder="e.g. VW Golf Mk7 (2013–2019)" style="flex:1;min-width:0;height:42px;border:1.5px solid #d8dee3;border-radius:8px;padding:0 12px;font:400 14px Barlow;color:#374754" />
        <button data-compat-rm="${i}" style="width:40px;height:42px;border:1.5px solid #f0d4d4;color:#c0392b;border-radius:8px;cursor:pointer;flex:none;font-size:16px;background:#fff">×</button>
      </div>`
    ).join('');
    wrap.querySelectorAll('[data-compat]').forEach((el) => el.addEventListener('input', () => { form.compatibility[+el.getAttribute('data-compat')] = el.value; }));
    wrap.querySelectorAll('[data-compat-rm]').forEach((b) => b.addEventListener('click', () => { form.compatibility.splice(+b.getAttribute('data-compat-rm'), 1); renderCompat(); }));
  }

  async function saveProduct() {
    // pull latest field values
    form.name = $('f-name').value;
    form.sku = $('f-sku').value;
    form.shortDesc = $('f-short').value;
    form.description = $('f-desc').value;
    form.category = $('f-category').value;
    form.condition = $('f-condition').value;
    if (!form.name.trim()) { $('f-name').focus(); return; }

    const gallery = form.gallery.map((g) => ({ src: g.src || null, label: g.label || '' }));
    const specs = form.specs.filter((s) => (s.label || '').trim() || (s.value || '').trim()).map((s) => ({ label: s.label.trim(), value: s.value.trim() }));
    const compatibility = form.compatibility.map((c) => c.trim()).filter(Boolean);

    if (editingId) {
      d.products = d.products.map((p) => p.id === editingId
        ? { ...p, name: form.name.trim(), category: form.category, condition: form.condition, sku: form.sku.trim(), shortDesc: form.shortDesc, description: form.description, gallery, specs, compatibility }
        : p);
    } else {
      const id = 'p' + Date.now();
      d.products.unshift({ id, slug: slugify(form.name), name: form.name.trim(), category: form.category, condition: form.condition, sku: form.sku.trim() || '—', shortDesc: form.shortDesc || '', description: form.description || '', gallery, specs, compatibility });
    }
    await store.persist();
    closeModal();
    adminPage = 1; renderTable();
  }

  // ---------- inline category / condition management ----------
  function renderManageList(kind) {
    const list = kind === 'cat' ? $('cat-manage-list') : $('cond-manage-list');
    const values = kind === 'cat' ? d.categories : d.conditions;
    const inUse = (v) => d.products.some((p) => (kind === 'cat' ? p.category : p.condition) === v);
    list.innerHTML = values.map((v) => {
      const used = inUse(v);
      const x = used
        ? `<span title="In use — can't remove" style="color:#c2cad0;cursor:not-allowed">×</span>`
        : `<span data-rm-val="${esc(v)}" title="Remove" style="color:#c0392b;cursor:pointer">×</span>`;
      return `<span style="display:inline-flex;align-items:center;gap:7px;background:#fff;border:1px solid #d8dee3;border-radius:20px;padding:4px 5px 4px 12px;font:500 12px Barlow;color:#374754">${esc(v)}${x}</span>`;
    }).join('');
    list.querySelectorAll('[data-rm-val]').forEach((b) => b.addEventListener('click', async () => {
      const v = b.getAttribute('data-rm-val');
      if (kind === 'cat') d.categories = d.categories.filter((x) => x !== v);
      else d.conditions = d.conditions.filter((x) => x !== v);
      await store.persist();
      renderManageList(kind);
      fillSelect(kind === 'cat' ? 'f-category' : 'f-condition', kind === 'cat' ? allCats() : allConds(), kind === 'cat' ? form.category : form.condition);
      renderChips(); renderHomeCats();
    }));
  }

  // ---------- wire events ----------
  $('btn-add').addEventListener('click', openAdd);
  $('modal-close').addEventListener('click', closeModal);
  $('modal-cancel').addEventListener('click', closeModal);
  $('modal-save').addEventListener('click', saveProduct);
  $('modal').addEventListener('click', (e) => { if (e.target === $('modal')) closeModal(); });

  $('chip-add').addEventListener('change', async (e) => {
    const v = e.target.value; e.target.value = '';
    if (v && !(d.settings.chipCats || []).includes(v)) { d.settings.chipCats = [...(d.settings.chipCats || []), v]; await store.persist(); renderChips(); }
  });
  $('home-add').addEventListener('change', async (e) => {
    const v = e.target.value; e.target.value = '';
    if (v && !(d.settings.homeCats || []).includes(v)) { d.settings.homeCats = [...(d.settings.homeCats || []), v]; await store.persist(); renderHomeCats(); }
  });
  $('cond-toggle').addEventListener('click', async () => {
    d.settings.conditionFilter = d.settings.conditionFilter === false ? true : false;
    await store.persist(); renderCondToggle();
  });

  let searchTimer;
  $('admin-search').addEventListener('input', (e) => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => { adminSearch = e.target.value; adminPage = 1; renderTable(); }, 150);
  });

  $('spec-add').addEventListener('click', () => { form.specs.push({ label: '', value: '' }); renderSpecs(); });
  $('compat-add').addEventListener('click', () => { form.compatibility.push(''); renderCompat(); });

  $('cat-manage').addEventListener('click', () => {
    const p = $('cat-manage-panel'); const show = p.style.display === 'none';
    p.style.display = show ? 'block' : 'none'; if (show) renderManageList('cat');
  });
  $('cond-manage').addEventListener('click', () => {
    const p = $('cond-manage-panel'); const show = p.style.display === 'none';
    p.style.display = show ? 'block' : 'none'; if (show) renderManageList('cond');
  });
  $('cat-add').addEventListener('click', async () => {
    const n = $('cat-new').value.trim(); if (!n) return;
    if (!d.categories.some((c) => c.toLowerCase() === n.toLowerCase())) d.categories.push(n);
    $('cat-new').value = ''; await store.persist();
    fillSelect('f-category', allCats(), n); form.category = n;
    renderManageList('cat'); renderChips(); renderHomeCats();
  });
  $('cond-add').addEventListener('click', async () => {
    const n = $('cond-new').value.trim(); if (!n) return;
    if (!d.conditions.some((c) => c.toLowerCase() === n.toLowerCase())) d.conditions.push(n);
    $('cond-new').value = ''; await store.persist();
    fillSelect('f-condition', allConds(), n); form.condition = n;
    renderManageList('cond');
  });

  // keep form.category/condition in sync when selects change
  $('f-category').addEventListener('change', (e) => { if (form) form.category = e.target.value; });
  $('f-condition').addEventListener('change', (e) => { if (form) form.condition = e.target.value; });

  renderAll();
</script>

---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import { loadProducts, loadSettings } from '../lib/content';

const products = loadProducts();
const settings = loadSettings();
const totalProducts = products.length;

const catCounts: Record<string, number> = {};
for (const p of products) {
  catCounts[p.category] = (catCounts[p.category] ?? 0) + 1;
}

const homeCategories = [
  { name: 'All parts', count: totalProducts },
  ...settings.homeCats.map((c) => ({ name: c, count: catCounts[c] ?? 0 })),
];

const featuredProducts = products.slice(0, 12);
---
<Base title="A&S Auto Parts">
  <Nav active="home" />

  <!-- HERO -->
  <div class="pad" style="padding-top:56px;padding-bottom:44px">
    <div class="hero-grid">
      <div>
        <div style="font:600 12px Barlow;letter-spacing:.18em;color:#FD843B;margin-bottom:16px;text-transform:uppercase">Genuine &amp; Quality Aftermarket</div>
        <h1 style="font:800 clamp(38px,5vw,56px)/1.04 Archivo;color:#374754;letter-spacing:-.02em;margin:0 0 18px">The right part,<br>the first time.</h1>
        <p style="font:400 17px/1.6 Barlow;color:#5c6770;margin:0 0 26px;max-width:480px">Lights, batteries, ABS pumps, engines, gearboxes and suspension — checked, sorted and ready to dispatch. Find your part, then send it over for a fast price.</p>
        <form action="/catalog" method="get" style="display:flex;gap:10px;max-width:500px">
          <input name="q" placeholder="Search by part name or description…" style="flex:1;border:1.5px solid #d8dee3;border-radius:9px;padding:0 16px;height:52px;font:400 15px Barlow;color:#374754" />
          <button type="submit" style="background:#374754;color:#fff;padding:0 24px;height:52px;display:flex;align-items:center;border-radius:9px;font:600 15px Barlow;cursor:pointer;border:none;white-space:nowrap">Search</button>
        </form>
        <div style="display:flex;gap:26px;margin-top:22px;font:500 14px Barlow;color:#5c6770">
          <span>✓ Trusted</span><span>✓ Expert support</span>
        </div>
        <a href="/contact" style="display:inline-flex;align-items:center;gap:8px;margin-top:20px;background:#FD843B;color:#fff;padding:13px 24px;border-radius:9px;font:600 15px Barlow;text-decoration:none">Contact us now to order →</a>
      </div>

      <div class="hide-xs" style="background:#f7f9fa;border:1px solid #eef1f3;border-radius:16px;padding:18px">
        <div style="font:700 15px Archivo;color:#374754;margin:2px 4px 12px;display:flex;align-items:center;justify-content:space-between;gap:8px">
          Shop by category
          <span style="font:500 12px Barlow;color:#9aa6ae">{totalProducts} parts</span>
        </div>
        <div style="display:flex;flex-direction:column;gap:7px" id="home-cats">
          {homeCategories.map((c, i) => (
            <a
              href={i === 0 ? '/' : `/catalog?category=${encodeURIComponent(c.name)}`}
              data-cat={c.name}
              class="home-cat-row"
              style="display:flex;justify-content:space-between;align-items:center;padding:10px 12px;border-radius:10px;border:1px solid #eef1f3;cursor:pointer;text-decoration:none;background:#fff;font:500 14px Barlow;color:#374754;transition:background .12s,color .12s"
            >
              <span>{c.name}</span>
              <span style="font:600 12px Barlow;color:#9aa6ae">{c.count}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="hero-contact" style="display:flex;flex-direction:column;gap:4px;align-items:flex-end;text-align:right">
        <div style="font:600 11px Barlow;letter-spacing:.14em;text-transform:uppercase;color:#9aa6ae">Call or email to order</div>
        <a href="tel:01234567890" style="text-decoration:none;font:800 22px Archivo;color:#374754;letter-spacing:-.01em">0123 456 7890</a>
        <a href="mailto:parts@asautoparts.co.uk" style="text-decoration:none;font:600 14px Barlow;color:#FD843B">parts@asautoparts.co.uk</a>
      </div>
    </div>
  </div>

  <!-- BROWSE -->
  <div class="pad" id="browse" style="padding-bottom:64px">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:22px;gap:16px;flex-wrap:wrap">
      <div>
        <h2 style="font:800 28px Archivo;color:#374754;letter-spacing:-.01em;margin:0">Browse our parts</h2>
        <div id="browse-subtitle" style="font:400 15px Barlow;color:#6b7780;margin-top:4px">Showing all parts · {totalProducts} results</div>
      </div>
      <a href="/catalog" style="font:600 14px Barlow;color:#FD843B;text-decoration:none">Open full catalog →</a>
    </div>
    <div class="cards" id="browse-grid">
      {featuredProducts.map((p) => <ProductCard product={p} />)}
    </div>
    <div class="pager" id="browse-pager" style="display:none"></div>
  </div>

  <!-- CONTACT BAND -->
  <div class="pad" style="padding-bottom:64px">
    <div style="background:#374754;border-radius:18px;padding:42px;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap">
      <div>
        <div style="font:800 28px Archivo;color:#fff;letter-spacing:-.01em">Can't find your part?</div>
        <div style="font:400 15px Barlow;color:#aeb8bf;margin-top:8px;max-width:480px">Flick us a call — we'll check if we can source it for you and get a price back to you fast.</div>
      </div>
      <a href="/contact" style="background:#FD843B;color:#fff;padding:15px 28px;border-radius:9px;font:600 16px Barlow;text-decoration:none;white-space:nowrap">Contact us</a>
    </div>
  </div>

  <Footer />
</Base>

<script define:vars={{ allProducts: products, totalProducts }}>
  const PER_PAGE = 12;
  let activeCat = 'All parts';
  let page = 1;

  const params = new URLSearchParams(window.location.search);
  const catParam = params.get('cat');
  if (catParam) activeCat = catParam;

  function filtered() {
    if (activeCat === 'All parts') return allProducts;
    return allProducts.filter((p) => p.category === activeCat);
  }

  function esc(s) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function cardHTML(p) {
    const thumb = p.gallery[0]?.src ?? null;
    const img = thumb
      ? `<img src="${esc(thumb)}" alt="${esc(p.name)}" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0" loading="lazy" />`
      : `<span>NO IMAGE</span>`;
    return `<a href="/catalog/${esc(p.slug)}" class="product-card">
      <div class="img-placeholder" style="height:172px;position:relative">${img}</div>
      <div style="padding:15px 17px;display:flex;flex-direction:column;gap:9px;flex:1">
        <div style="display:flex;gap:7px;align-items:center">
          <span style="background:#eef1f3;color:#374754;font:600 11px Barlow;padding:3px 9px;border-radius:20px">${esc(p.category)}</span>
          <span style="color:#FD843B;font:600 11px Barlow">${esc(p.condition)}</span>
        </div>
        <div style="font:700 16px Archivo;color:#374754;line-height:1.25">${esc(p.name)}</div>
        <div style="font:400 13.5px/1.5 Barlow;color:#6b7780">${esc(p.shortDesc)}</div>
        <div style="margin-top:auto;font:600 13px Barlow;color:#374754">View details →</div>
      </div>
    </a>`;
  }

  function pagerHTML(cur, total) {
    const pd = cur <= 1, nd = cur >= total;
    let h = `<button class="pager-btn${pd?' pager-btn--disabled':''}" data-page="prev">←</button>`;
    for (let i = 1; i <= total; i++)
      h += `<button class="pager-btn${i===cur?' pager-btn--active':''}" data-page="${i}">${i}</button>`;
    h += `<button class="pager-btn${nd?' pager-btn--disabled':''}" data-page="next">→</button>`;
    return h;
  }

  function render() {
    const f = filtered();
    const totalPages = Math.ceil(f.length / PER_PAGE);
    page = Math.max(1, Math.min(page, totalPages || 1));
    const slice = f.slice((page - 1) * PER_PAGE, page * PER_PAGE);

    document.getElementById('browse-subtitle').textContent =
      `Showing ${activeCat === 'All parts' ? 'all parts' : activeCat} · ${f.length} result${f.length === 1 ? '' : 's'}`;

    document.getElementById('browse-grid').innerHTML = slice.map(cardHTML).join('');

    const pager = document.getElementById('browse-pager');
    if (totalPages <= 1) {
      pager.style.display = 'none';
    } else {
      pager.style.display = 'flex';
      pager.innerHTML = pagerHTML(page, totalPages);
      pager.querySelectorAll('[data-page]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const v = btn.getAttribute('data-page');
          if (v === 'prev') page--; else if (v === 'next') page++; else page = +v;
          render();
          const mo = window.matchMedia('(prefers-reduced-motion: reduce)');
          document.getElementById('browse').scrollIntoView({ behavior: mo.matches ? 'auto' : 'smooth', block: 'start' });
        });
      });
    }

    document.querySelectorAll('.home-cat-row').forEach((el) => {
      const cat = el.getAttribute('data-cat');
      const active = cat === activeCat;
      el.style.background = active ? '#374754' : '#fff';
      el.style.color = active ? '#fff' : '#374754';
      el.style.borderColor = active ? '#374754' : '#eef1f3';
      el.querySelector('span:last-child').style.color = active ? 'rgba(255,255,255,.7)' : '#9aa6ae';
    });
  }

  document.querySelectorAll('.home-cat-row').forEach((el) => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      activeCat = el.getAttribute('data-cat');
      page = 1;
      render();
      const mo = window.matchMedia('(prefers-reduced-motion: reduce)');
      document.getElementById('browse').scrollIntoView({ behavior: mo.matches ? 'auto' : 'smooth', block: 'start' });
    });
  });

  render();
</script>
